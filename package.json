{
  "name": "surreal-tools",
  "version": "0.0.2",
  "type": "module",
  "author": {
    "name": "Torsten Blindert"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:declaration": "tsc -p tsconfig.declaration.json",
    "build:src": "bun run build.ts",
    "build": "bun build:src && bun build:declaration",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "check-types": "tsc",
    "check-format": "prettier --check .",
    "test": "bun check-types && bun lint && bun check-format && bun test",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": "github:Torsten85/surreal-tools",
  "homepage": "https://github.com/Torsten85/surreal-tools",
  "bin": {
    "surreal-tools": "./dist/cli.js"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@surrealdb/node": "^3.0.1",
    "@types/bun": "latest",
    "@types/yargs": "^17.0.35",
    "eslint": "^10.0.2",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "typescript-eslint": "^8.56.1"
  },
  "peerDependencies": {
    "typescript": "^5.8.3",
    "@surrealdb/node": "^3.0.1"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "prettier": "^3.8.1",
    "surrealdb": "^2.0.0",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "peerDependenciesMeta": {
    "@surrealdb/node": {
      "optional": true
    }
  }
}
